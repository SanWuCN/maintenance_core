<view class="page-shell confirm-page">
  <view class="title-panel">
    <view>
      <view class="section-title">确认订单</view>
      <view class="muted">核对无误后再付款预定</view>
    </view>
  </view>

  <view class="order-card">
    <view class="order-hero">
      <view>
        <view class="hero-title">{{booking.service.name}}</view>
        <view class="hero-sub">{{booking.service.desc}}</view>
      </view>
      <view class="hero-price">
        <view>¥{{totalPrice}}</view>
        <text>总价</text>
      </view>
    </view>

    <view class="detail-list">
      <view wx:for="{{detailRows}}" wx:key="label" class="detail-row">
        <image class="detail-icon" src="{{item.icon}}" mode="aspectFit" />
        <text class="detail-label">{{item.label}}</text>
        <text class="detail-value">{{item.value}}</text>
      </view>
      <view wx:if="{{booking.device.note}}" class="detail-row note-row">
        <image class="detail-icon" src="/static/confirm/device.png" mode="aspectFit" />
        <text class="detail-label">设备备注</text>
        <text class="detail-value">{{booking.device.note}}</text>
      </view>
      <view wx:if="{{booking.dorm.addressNote}}" class="detail-row note-row">
        <image class="detail-icon" src="/static/confirm/address.png" mode="aspectFit" />
        <text class="detail-label">交接备注</text>
        <text class="detail-value">{{booking.dorm.addressNote}}</text>
      </view>
    </view>
  </view>

  <view class="addon-card confirm-card" wx:if="{{hasAddons}}">
    <view class="card-head">
      <view class="hex-mark">
        <image src="/static/confirm/grease-white.png" mode="aspectFit" />
      </view>
      <view class="card-title">附加服务</view>
      <view class="card-badge">专业服务 · 安心保障</view>
    </view>
    <view wx:for="{{addonRows}}" wx:key="id" class="addon-row">
      <text class="addon-name">{{item.name}}</text>
      <view class="addon-dash"></view>
      <text wx:if="{{item.oldPriceText}}" class="old-price">{{item.oldPriceText}}</text>
      <text class="free-price">{{item.priceText}}</text>
    </view>
  </view>

  <view class="promise-card confirm-card">
    <view class="promise-head">
      <view class="promise-shield">✓</view>
      <view>
        <view class="card-title">支付承诺</view>
        <view class="promise-copy">配送形式：楼下取机，楼下送回</view>
      </view>
    </view>
    <view class="promise-icons">
      <view wx:for="{{promiseItems}}" wx:key="label" class="promise-item">
        <image src="{{item.icon}}" mode="aspectFit" />
        <text>{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="pay-bar" wx:if="{{actionReady}}">
    <view class="pay-total">
      <view class="pay-symbol">¥</view>
      <view>
        <view class="pay-label">实付总价</view>
        <view class="pay-price">¥{{totalPrice}}</view>
      </view>
    </view>
    <view class="pay-actions">
      <button class="edit-btn" bindtap="backEdit">返回修改</button>
      <button class="pay-btn" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submit">付款预定</button>
    </view>
  </view>
</view>
