.confirm-page {
  min-height: 100vh;
  padding-bottom: 166rpx;
  background: #f4f4f2;
  box-sizing: border-box;
}

.step-line {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10rpx;
  margin-bottom: 34rpx;
}

.step {
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #9a9a9a;
  text-align: center;
  font-size: 22rpx;
  border: 1rpx solid #e8e8e3;
}

.step.active,
.step.done {
  background: #111111;
  color: #ffffff;
}

.step.locked {
  opacity: 0.48;
}

.step.clickable {
  transform: translateZ(0);
}

.title-block {
  margin-bottom: 24rpx;
}

.summary-card,
.gift-card,
.promise-card {
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.summary-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.summary-title {
  font-size: 36rpx;
  font-weight: 900;
}

.summary-sub {
  margin-top: 8rpx;
  color: #777777;
  font-size: 23rpx;
}

.summary-price {
  font-size: 44rpx;
  font-weight: 900;
}

.divider {
  height: 1rpx;
  background: #ededed;
  margin: 24rpx 0;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 13rpx 0;
  font-size: 25rpx;
}

.label {
  flex-shrink: 0;
  color: #777777;
}

.value {
  text-align: right;
  font-weight: 700;
}

.gift-title,
.promise-title {
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.gift-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 12rpx 0;
  color: #333333;
  font-size: 24rpx;
}

.old-price {
  color: #999999;
  text-decoration: line-through;
}

.free-price {
  color: #111111;
  font-weight: 900;
}

.promise-row {
  color: #666666;
  font-size: 24rpx;
  line-height: 1.75;
}

.action-row {
  display: grid;
  grid-template-columns: 210rpx 1fr;
  gap: 16rpx;
}

.fixed-action {
  position: fixed;
  z-index: 20;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(244, 244, 242, 0.96);
  box-shadow: 0 -12rpx 34rpx rgba(20, 20, 20, 0.08);
  box-sizing: border-box;
}
