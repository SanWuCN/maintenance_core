.reviews-page {
  min-height: 100vh;
  background: #f5f5f3;
}

.review-tabs {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  height: 104rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 26rpx rgba(20,20,20,0.06);
}

.review-tab {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #777777;
  font-size: 30rpx;
  font-weight: 800;
}

.review-tab.active {
  color: #111111;
}

.review-tab.active::after {
  content: "";
  position: absolute;
  bottom: 0;
  width: 88rpx;
  height: 7rpx;
  border-radius: 999rpx;
  background: #111111;
}

.empty-state {
  height: 680rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-illus {
  width: 160rpx;
  height: 124rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #e8e8e6, #f4f4f2);
  opacity: 0.72;
}

.empty-title {
  margin-top: 44rpx;
  color: #999999;
  font-size: 30rpx;
}
