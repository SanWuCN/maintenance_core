<view class="reviews-page">
  <view class="review-tabs">
    <view class="review-tab {{activeTab === 'pending' ? 'active' : ''}}" data-key="pending" bindtap="switchTab">待评价</view>
    <view class="review-tab {{activeTab === 'done' ? 'active' : ''}}" data-key="done" bindtap="switchTab">已评价</view>
  </view>
  <view class="empty-state">
    <view class="empty-illus"></view>
    <view class="empty-title">暂无评价</view>
  </view>
</view>
