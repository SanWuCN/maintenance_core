<view class="page-shell flow-page {{showDatePicker ? 'no-scroll' : ''}}">
  <view class="step-line">
    <view
      wx:for="{{flowSteps}}"
      wx:key="key"
      class="step {{item.state}} {{item.lockClass}}"
      data-key="{{item.key}}"
      bindtap="goFlowStep"
    >{{item.label}}</view>
  </view>

  <view class="schedule-panel tech-card">
    <view class="schedule-head">
      <view class="schedule-copy">
        <view class="schedule-title">预约时间</view>
      </view>
      <view class="selected-date-trigger" bindtap="openDatePicker">
        <text>{{selectedDateText}}</text>
        <view class="date-arrow"></view>
      </view>
      <view class="calendar-link" bindtap="openDatePicker">项目日历</view>
    </view>

    <scroll-view class="date-strip" scroll-x show-scrollbar="{{false}}" scroll-into-view="d{{selectedDate}}">
      <view
        wx:for="{{dates}}"
        wx:key="value"
        id="d{{item.value}}"
        class="date-item {{selectedDate === item.value ? 'selected' : ''}}"
        data-value="{{item.value}}"
        bindtap="selectDate"
      >
        <view class="date-week">{{item.stripLabel}}</view>
        <view class="date-day">{{item.stripDate}}</view>
      </view>
    </scroll-view>
  </view>

  <view class="slot-list">
    <view
      wx:for="{{slots}}"
      wx:key="id"
      class="slot-card tech-card {{selectedSlotId === item.id ? 'selected' : ''}} {{item.remaining === 0 ? 'disabled' : ''}}"
      data-id="{{item.id}}"
      bindtap="selectSlot"
    >
      <view class="slot-info">
        <view class="slot-time">{{item.time}}</view>
      </view>
      <view class="slot-right">
        <view class="remaining">余 {{item.remaining}}</view>
        <view class="slot-dot"></view>
      </view>
    </view>
  </view>

  <view class="rule-card tech-card">
    <view class="rule-title">预约规则</view>
    <view class="rule-row">请提前 10 分钟到宿舍楼下交接。</view>
    <view class="rule-row">如需取消，请提前 2 小时联系处理。</view>
  </view>

  <view class="fixed-action" wx:if="{{actionReady}}">
    <button class="primary-btn bottom-action" loading="{{navigating}}" disabled="{{navigating}}" bindtap="next">下一步：填写设备</button>
  </view>
</view>

<view class="picker-mask {{showDatePicker ? 'show' : ''}}" bindtap="closeDatePicker"></view>
<view class="picker-popup {{showDatePicker ? 'show' : ''}}">
  <view class="picker-header">
    <view class="picker-title">选择日期</view>
    <view class="picker-close" bindtap="closeDatePicker">×</view>
  </view>
  <scroll-view class="picker-body" scroll-y>
    <view wx:for="{{calendarMonths}}" wx:key="key" class="calendar-month">
      <view class="month-title">{{item.title}}</view>
      <view class="weekday-row">
        <text>日</text>
        <text>一</text>
        <text>二</text>
        <text>三</text>
        <text>四</text>
        <text>五</text>
        <text>六</text>
      </view>
      <view class="month-grid">
        <view class="month-watermark">{{item.watermark}}</view>
        <view
          wx:for="{{item.cells}}"
          wx:for-item="day"
          wx:key="key"
          class="calendar-cell {{day.className}} {{selectedDate === day.value ? 'selected' : ''}}"
          data-value="{{day.value}}"
          bindtap="selectPickerDate"
        >
          <view wx:if="{{day.visible}}">
            <view class="calendar-day">{{day.day}}</view>
            <view class="available-text" wx:if="{{day.available}}">可预约</view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
  <view class="picker-action">
    <button class="primary-btn picker-confirm" bindtap="confirmDatePicker">确定</button>
  </view>
</view>
