<view class="page-shell flow-page">
  <view class="step-line">
    <view
      wx:for="{{flowSteps}}"
      wx:key="key"
      class="step {{item.state}} {{item.lockClass}}"
      data-key="{{item.key}}"
      bindtap="goFlowStep"
    >{{item.label}}</view>
  </view>

  <view class="title-block">
    <view class="section-title">选择项目</view>
    <view class="muted">先选主服务，再按需勾选附加项。</view>
  </view>

  <view class="service-list">
    <view
      wx:for="{{services}}"
      wx:key="id"
      class="service-card tech-card {{selectedServiceId === item.id ? 'selected' : ''}}"
      data-id="{{item.id}}"
      bindtap="selectService"
    >
      <view class="service-main">
        <view>
          <view class="service-title">{{item.name}}</view>
          <view class="service-desc">{{item.desc}}</view>
        </view>
        <view class="service-price">¥{{item.price}}</view>
      </view>
      <view class="tag-row">
        <text wx:for="{{item.tags}}" wx:key="*this" class="tag">{{item}}</text>
      </view>
      <view class="check-dot"></view>
    </view>
  </view>

  <view class="addon-panel tech-card">
    <view class="addon-head">
      <view class="addon-title">附加服务</view>
      <view class="addon-note">可自由勾选</view>
    </view>
    <view wx:for="{{addons}}" wx:key="id" class="addon-row {{item.selected ? 'selected' : ''}}" data-id="{{item.id}}" bindtap="toggleAddon">
      <view class="addon-check {{item.selected ? 'checked' : ''}}"></view>
      <view class="addon-name">{{item.name}}</view>
      <view class="addon-price">
        <text wx:if="{{item.free}}" class="old-price">+{{item.oldPrice}} RMB</text>
        <text wx:if="{{item.free}}" class="free-price">0 RMB</text>
        <text wx:else class="paid-price">+{{item.price}} RMB</text>
      </view>
    </view>
  </view>

  <view class="fixed-action" wx:if="{{actionReady}}">
    <button class="primary-btn bottom-action" loading="{{navigating}}" disabled="{{navigating}}" bindtap="next">下一步：预约时间</button>
  </view>

  <view wx:if="{{greaseModalVisible}}" class="grease-mask" catchtouchmove="noop">
    <view class="grease-modal">
      <view class="grease-modal-head">
        <view>
          <view class="grease-modal-title">选择硅脂</view>
          <view class="grease-modal-copy">清灰换脂需确认散热材料</view>
        </view>
        <view class="grease-close" bindtap="closeGreaseModal">×</view>
      </view>
      <view class="grease-list">
        <view
          wx:for="{{greases}}"
          wx:key="id"
          class="grease-row {{selectedGreaseId === item.id ? 'selected' : ''}}"
          data-id="{{item.id}}"
          bindtap="selectGrease"
        >
          <view>
            <view class="grease-name">{{item.name}} <text wx:if="{{item.tag}}" class="grease-tag">{{item.tag}}</text></view>
            <input
              wx:if="{{item.custom && selectedGreaseId === item.id}}"
              class="grease-input"
              placeholder="填写硅脂 / 相变片名称"
              value="{{customGrease}}"
              bindinput="onCustomGrease"
              catchtap="noop"
            />
          </view>
          <view wx:if="{{item.price}}" class="grease-price">+{{item.price}} RMB</view>
          <view wx:else class="grease-price">+0 RMB</view>
          <view class="grease-dot"></view>
        </view>
      </view>
      <button class="primary-btn grease-confirm" loading="{{navigating}}" disabled="{{navigating}}" bindtap="confirmGrease">确认并继续</button>
    </view>
  </view>
</view>
