<view class="page-shell flow-page">
  <view class="step-line">
    <text class="step active">服务</text>
    <text class="step">时间</text>
    <text class="step">设备</text>
    <text class="step">宿舍</text>
  </view>

  <view class="title-block">
    <view class="section-title">选择清灰维护项目</view>
    <view class="muted">先选主服务，附加保养默认赠送。</view>
  </view>

  <view class="service-list">
    <view
      wx:for="{{services}}"
      wx:key="id"
      class="service-card tech-card {{selectedServiceId === item.id ? 'selected' : ''}}"
      data-id="{{item.id}}"
      bindtap="selectService"
    >
      <view class="service-main">
        <view>
          <view class="service-title">{{item.name}}</view>
          <view class="service-desc">{{item.desc}}</view>
        </view>
        <view class="service-price">¥{{item.price}}</view>
      </view>
      <view class="tag-row">
        <text wx:for="{{item.tags}}" wx:key="*this" class="tag">{{item}}</text>
      </view>
      <view class="check-dot"></view>
    </view>
  </view>

  <view class="addon-panel tech-card">
    <view class="addon-head">
      <view class="addon-title">附加服务</view>
      <view class="addon-note">默认包含 · 当前免费</view>
    </view>
    <view wx:for="{{addons}}" wx:key="name" class="addon-row">
      <view class="addon-check"></view>
      <view class="addon-name">{{item.name}}</view>
      <view class="addon-price">
        <text class="old-price">+{{item.oldPrice}} RMB</text>
        <text class="free-price">0 RMB</text>
      </view>
    </view>
  </view>

  <view class="notice tech-card">
    <view class="notice-title">配送形式</view>
    <view class="notice-copy">我们到宿舍楼下取机，清理完成后送回楼下；清灰过程全程视频记录。</view>
  </view>

  <button class="primary-btn bottom-action" bindtap="next">下一步：预约时间</button>
</view>
