.flow-page {
  min-height: 100vh;
  padding-bottom: 180rpx;
  background: #f4f4f2;
  box-sizing: border-box;
}

.step-line {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10rpx;
  margin-bottom: 34rpx;
}

.step {
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #9a9a9a;
  text-align: center;
  font-size: 22rpx;
  border: 1rpx solid #e8e8e3;
}

.step.active,
.step.done {
  background: #111111;
  color: #ffffff;
}

.step.locked {
  opacity: 0.48;
}

.step.clickable {
  transform: translateZ(0);
}

.title-block {
  margin-bottom: 24rpx;
}

.service-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.service-card {
  position: relative;
  padding: 30rpx;
  overflow: hidden;
}

.service-card.selected {
  border-color: #111111;
  background: #111111;
  color: #ffffff;
}

.service-main {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.service-title {
  font-size: 34rpx;
  font-weight: 900;
}

.service-desc {
  margin-top: 12rpx;
  color: #707070;
  font-size: 23rpx;
  line-height: 1.45;
}

.service-card.selected .service-desc {
  color: rgba(255, 255, 255, 0.72);
}

.service-price {
  flex-shrink: 0;
  font-size: 40rpx;
  font-weight: 900;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 22rpx;
}

.tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #111111;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 800;
}

.service-card.selected .tag {
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
}

.check-dot {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  border: 2rpx solid #cfcfca;
}

.selected .check-dot {
  background: #ffffff;
  border-color: #ffffff;
}

.addon-panel,
.grease-panel {
  margin-top: 22rpx;
  padding: 28rpx;
}

.addon-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.addon-title,
.grease-title {
  font-size: 30rpx;
  font-weight: 900;
}

.addon-note {
  color: #777777;
  font-size: 22rpx;
}

.addon-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 78rpx;
  border-top: 1rpx solid #f0f0ed;
}

.addon-check {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid #c9c9c4;
  position: relative;
  box-sizing: border-box;
}

.addon-check.checked {
  background: #111111;
  border-color: #111111;
}

.addon-check.checked::after {
  content: "";
  position: absolute;
  left: 6rpx;
  top: 5rpx;
  width: 10rpx;
  height: 6rpx;
  border-left: 3rpx solid #ffffff;
  border-bottom: 3rpx solid #ffffff;
  transform: rotate(-45deg);
}

.addon-name {
  flex: 1;
  font-size: 25rpx;
  font-weight: 700;
}

.addon-price {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
  font-size: 20rpx;
}

.old-price {
  color: #999999;
  text-decoration: line-through;
}

.free-price {
  color: #111111;
  font-weight: 900;
}

.paid-price {
  color: #111111;
  font-weight: 900;
}

.grease-row {
  position: relative;
  min-height: 82rpx;
  padding: 18rpx 58rpx 18rpx 0;
  border-top: 1rpx solid #f0f0ed;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.grease-name {
  color: #1c1c1c;
  font-size: 26rpx;
  font-weight: 800;
}

.grease-tag {
  margin-left: 8rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #111111;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 800;
}

.grease-price {
  color: #111111;
  font-size: 23rpx;
  font-weight: 900;
}

.grease-dot {
  position: absolute;
  right: 0;
  top: 50%;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid #c9c9c4;
  transform: translateY(-50%);
  box-sizing: border-box;
}

.grease-row.selected .grease-dot {
  border-color: #111111;
  background: #111111;
  box-shadow: inset 0 0 0 8rpx #ffffff;
}

.grease-input {
  width: 360rpx;
  height: 70rpx;
  margin-top: 12rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  background: #f5f5f2;
  border: 1rpx solid #ecece8;
  box-sizing: border-box;
  font-size: 24rpx;
}

.fixed-action {
  position: fixed;
  z-index: 20;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.bottom-action {
  width: 100%;
  box-sizing: border-box;
  box-shadow: 0 18rpx 34rpx rgba(0, 0, 0, 0.18);
}

.grease-mask {
  position: fixed;
  z-index: 50;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  padding: 0 32rpx;
  background: rgba(0, 0, 0, 0.42);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  backdrop-filter: blur(6rpx);
  -webkit-backdrop-filter: blur(6rpx);
}

.grease-modal {
  width: 100%;
  padding: 34rpx 30rpx 30rpx;
  border-radius: 34rpx;
  background: #ffffff;
  box-shadow: 0 28rpx 80rpx rgba(0, 0, 0, 0.22);
  box-sizing: border-box;
}

.grease-modal-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.grease-modal-title {
  font-size: 34rpx;
  font-weight: 900;
}

.grease-modal-copy {
  margin-top: 8rpx;
  color: #777777;
  font-size: 23rpx;
}

.grease-close {
  width: 60rpx;
  height: 60rpx;
  line-height: 54rpx;
  color: #777777;
  font-size: 48rpx;
  text-align: center;
}

.grease-list {
  border-top: 1rpx solid #f0f0ed;
}

.grease-confirm {
  width: 100%;
  margin-top: 28rpx;
  box-sizing: border-box;
}
