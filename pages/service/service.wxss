.flow-page {
  padding-bottom: 150rpx;
}

.step-line {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-bottom: 34rpx;
}

.step {
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #9a9a9a;
  text-align: center;
  font-size: 22rpx;
  border: 1rpx solid #e8e8e3;
}

.step.active {
  background: #111111;
  color: #ffffff;
}

.title-block {
  margin-bottom: 24rpx;
}

.service-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.service-card {
  position: relative;
  padding: 30rpx;
  overflow: hidden;
}

.service-card.selected {
  border-color: #111111;
}

.service-main {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.service-title {
  font-size: 34rpx;
  font-weight: 900;
}

.service-desc {
  margin-top: 12rpx;
  color: #707070;
  font-size: 24rpx;
  line-height: 1.55;
}

.service-price {
  flex-shrink: 0;
  font-size: 40rpx;
  font-weight: 900;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 22rpx;
}

.tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f1f1ee;
  color: #4e4e4e;
  font-size: 20rpx;
}

.check-dot {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  border: 2rpx solid #cfcfca;
}

.selected .check-dot {
  background: #111111;
  border-color: #111111;
}

.addon-panel,
.notice {
  margin-top: 22rpx;
  padding: 28rpx;
}

.addon-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.addon-title,
.notice-title {
  font-size: 30rpx;
  font-weight: 900;
}

.addon-note {
  color: #777777;
  font-size: 22rpx;
}

.addon-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 78rpx;
  border-top: 1rpx solid #f0f0ed;
}

.addon-check {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #111111;
  position: relative;
}

.addon-check::after {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 6rpx;
  width: 10rpx;
  height: 6rpx;
  border-left: 3rpx solid #ffffff;
  border-bottom: 3rpx solid #ffffff;
  transform: rotate(-45deg);
}

.addon-name {
  flex: 1;
  font-size: 25rpx;
  font-weight: 700;
}

.addon-price {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
  font-size: 20rpx;
}

.old-price {
  color: #999999;
  text-decoration: line-through;
}

.free-price {
  color: #111111;
  font-weight: 900;
}

.notice-copy {
  margin-top: 12rpx;
  color: #666666;
  font-size: 24rpx;
  line-height: 1.6;
}

.bottom-action {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  z-index: 5;
}
