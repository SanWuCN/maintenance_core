.activity-page {
  padding: 24rpx;
}

.page-head {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.head-btn {
  width: 112rpx;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 999rpx;
  background: #111111;
  color: #ffffff;
  font-size: 24rpx;
  padding: 0;
}

.poster-strip {
  white-space: nowrap;
  margin: 0 -24rpx 20rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.poster-thumb {
  display: inline-block;
  width: 420rpx;
  height: 748rpx;
  margin-right: 18rpx;
  border-radius: 28rpx;
  box-shadow: 0 18rpx 44rpx rgba(0, 0, 0, 0.1);
  background: #eeeeeb;
}

.campaign {
  padding: 34rpx;
  background: #111111;
  color: #ffffff;
}

.campaign-k {
  color: #c9c9c9;
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.campaign-title {
  margin-top: 14rpx;
  font-size: 48rpx;
  line-height: 1.1;
  font-weight: 800;
}

.campaign-copy {
  margin-top: 12rpx;
  color: #d7d7d7;
  font-size: 24rpx;
}

.mini-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.mini-card {
  padding: 24rpx 10rpx;
  text-align: center;
}

.mini-value {
  font-size: 42rpx;
  font-weight: 800;
}

.mini-label {
  margin-top: 4rpx;
  color: #777777;
  font-size: 20rpx;
}
