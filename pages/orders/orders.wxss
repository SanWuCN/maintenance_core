.orders-page {
  min-height: 100vh;
  background: #f5f5f3;
  padding: 28rpx;
  box-sizing: border-box;
}

.search-box {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  background: #eeeeec;
  color: #b7b7b2;
  text-align: center;
  font-size: 28rpx;
  margin-bottom: 28rpx;
}

.tabs {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10rpx;
  margin-bottom: 26rpx;
}

.tab {
  height: 62rpx;
  line-height: 62rpx;
  text-align: center;
  color: #666666;
  font-size: 27rpx;
  font-weight: 800;
}

.tab.active {
  color: #111111;
  position: relative;
}

.tab.active::after {
  content: "";
  position: absolute;
  left: 24%;
  right: 24%;
  bottom: 0;
  height: 7rpx;
  border-radius: 999rpx;
  background: #111111;
}

.order-card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 34rpx rgba(20,20,20,0.05);
}

.order-top,
.order-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-top text {
  font-size: 32rpx;
  font-weight: 950;
}

.order-top view {
  color: #777777;
  font-size: 24rpx;
}

.order-line {
  margin-top: 12rpx;
  color: #777777;
  font-size: 25rpx;
}

.order-bottom {
  margin-top: 22rpx;
}

.order-bottom text {
  font-size: 34rpx;
  font-weight: 950;
}

.order-bottom button {
  width: 160rpx;
  height: 62rpx;
  line-height: 62rpx;
  border-radius: 999rpx;
  padding: 0;
  background: #111111;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
}

.empty-state {
  height: 620rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  width: 126rpx;
  height: 150rpx;
  border-radius: 18rpx 18rpx 28rpx 28rpx;
  background: linear-gradient(180deg, #e1e1df, #f1f1ef);
  clip-path: polygon(0 0, 100% 0, 100% 84%, 82% 72%, 64% 84%, 48% 72%, 32% 84%, 16% 72%, 0 84%);
}

.empty-title {
  margin-top: 42rpx;
  font-size: 32rpx;
  font-weight: 950;
}

.empty-copy {
  margin-top: 12rpx;
  color: #999999;
  font-size: 27rpx;
}
