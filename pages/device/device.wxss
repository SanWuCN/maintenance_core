.flow-page {
  padding-bottom: 150rpx;
}

.step-line {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-bottom: 34rpx;
}

.step {
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #9a9a9a;
  text-align: center;
  font-size: 22rpx;
  border: 1rpx solid #e8e8e3;
}

.step.active,
.step.done {
  background: #111111;
  color: #ffffff;
}

.title-block {
  margin-bottom: 24rpx;
}

.picker-card,
.form-card {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.block-title {
  margin-bottom: 18rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  background: #f3f3f0;
  color: #333333;
  font-size: 24rpx;
  font-weight: 700;
}

.chip.selected {
  background: #111111;
  color: #ffffff;
}

.model-row {
  min-height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid #f0f0ed;
  font-size: 26rpx;
  font-weight: 700;
}

.model-row:first-child {
  border-top: 0;
}

.model-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid #cfcfca;
}

.model-row.selected .model-dot {
  background: #111111;
  border-color: #111111;
}

.text-input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: #f7f7f4;
  border: 1rpx solid #ededed;
  font-size: 25rpx;
}

.text-input {
  height: 88rpx;
  padding: 0 22rpx;
}

.textarea {
  min-height: 160rpx;
  margin-top: 16rpx;
  padding: 22rpx;
}

.bottom-action {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  z-index: 5;
}
