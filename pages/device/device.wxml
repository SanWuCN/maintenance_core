<view class="page-shell flow-page">
  <view class="step-line">
    <text class="step done">服务</text>
    <text class="step done">时间</text>
    <text class="step active">设备</text>
    <text class="step">地址</text>
    <text class="step">确认</text>
  </view>

  <view class="title-block">
    <view class="section-title">选择设备型号</view>
    <view class="muted">优先点选常见品牌和型号，也可以手动填写。</view>
  </view>

  <view class="tech-card picker-card">
    <view class="block-title">品牌</view>
    <view class="chip-grid">
      <view
        wx:for="{{brands}}"
        wx:key="*this"
        class="chip {{selectedBrand === item ? 'selected' : ''}}"
        data-brand="{{item}}"
        bindtap="selectBrand"
      >{{item}}</view>
    </view>
  </view>

  <view class="tech-card picker-card">
    <view class="block-title">常用型号</view>
    <view class="model-list">
      <view
        wx:for="{{models}}"
        wx:key="*this"
        class="model-row {{selectedModel === item ? 'selected' : ''}}"
        data-model="{{item}}"
        bindtap="selectModel"
      >
        <text>{{item}}</text>
        <view class="model-dot"></view>
      </view>
    </view>
  </view>

  <view class="tech-card form-card">
    <view class="block-title">补充信息</view>
    <input class="text-input" placeholder="自定义型号，如 ROG 魔霸新锐 2023" value="{{customModel}}" bindinput="onCustomModel" />
    <textarea class="textarea" placeholder="可填写温度高、异响、进灰严重、多久没清灰等情况" value="{{deviceNote}}" bindinput="onNote" />
  </view>

  <view class="fixed-action" wx:if="{{actionReady}}">
    <button class="primary-btn bottom-action" loading="{{navigating}}" disabled="{{navigating}}" bindtap="next">下一步：填写地址</button>
  </view>
</view>
