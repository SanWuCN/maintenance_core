.profile-page {
  min-height: 100vh;
  background: #f5f5f3;
  padding-bottom: 80rpx;
}

.section-label {
  padding: 34rpx 28rpx 18rpx;
  color: #999999;
  font-size: 30rpx;
}

.profile-card {
  background: #ffffff;
}

.profile-row {
  min-height: 104rpx;
  margin-left: 28rpx;
  padding-right: 28rpx;
  border-bottom: 1rpx solid #eeeeee;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #333333;
  font-size: 30rpx;
}

.profile-row.last {
  border-bottom: 0;
}

.row-right {
  display: flex;
  align-items: center;
  gap: 18rpx;
  color: #333333;
}

.avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: #111111;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
}

.arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 4rpx solid #aaaaaa;
  border-right: 4rpx solid #aaaaaa;
  transform: rotate(45deg);
}

.gender-group {
  display: flex;
  gap: 22rpx;
}

.gender-btn {
  width: 150rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  text-align: center;
  background: #f3f3f2;
}

.gender-btn.active {
  background: #111111;
  color: #ffffff;
}

.row-title {
  font-size: 30rpx;
  color: #333333;
}

.row-sub {
  margin-top: 8rpx;
  color: #999999;
  font-size: 24rpx;
}
