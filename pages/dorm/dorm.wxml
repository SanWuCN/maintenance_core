<view class="page-shell flow-page">
  <view class="step-line">
    <view
      wx:for="{{flowSteps}}"
      wx:key="key"
      class="step {{item.state}} {{item.lockClass}}"
      data-key="{{item.key}}"
      bindtap="goFlowStep"
    >{{item.label}}</view>
  </view>

  <view class="title-block">
    <view class="section-title">选择地址</view>
    <view class="muted">选择宿舍楼，交接精确到楼下。</view>
  </view>

  <view class="tech-card map-card">
    <view class="map-head">
      <view class="block-title">生活园区</view>
      <view class="map-current">{{selectedDorm}}</view>
    </view>
    <view class="dorm-map">
      <view
        wx:for="{{dorms}}"
        wx:key="label"
        class="dorm-building {{item.className}} {{selectedDorm === item.label ? 'selected' : ''}} {{item.disabled ? 'disabled' : ''}}"
        data-dorm="{{item.label}}"
        bindtap="selectDorm"
      >
        <view class="building-body"></view>
        <view class="building-label">{{item.label}}</view>
      </view>
    </view>
  </view>

  <view class="tech-card form-card">
    <view class="block-title">联系方式</view>
    <input class="text-input" placeholder="姓名 / 称呼" value="{{contactName}}" bindinput="onName" />
    <input class="text-input" type="number" placeholder="手机号或微信号" value="{{contactPhone}}" bindinput="onPhone" />
    <textarea class="textarea" placeholder="补充说明，如楼下具体交接点、方便联系时间" value="{{addressNote}}" bindinput="onNote" />
  </view>

  <view class="tech-card delivery-card">
    <view class="block-title">交付说明</view>
    <view class="delivery-row">配送形式：楼下取机，楼下送回。</view>
    <view class="delivery-row">不会进入宿舍，请提前 10 分钟到楼下交接。</view>
    <view class="delivery-row">全程视频记录，关键步骤可发送确认。</view>
  </view>

  <view class="fixed-action" wx:if="{{actionReady}}">
    <button class="primary-btn bottom-action" loading="{{navigating}}" disabled="{{navigating}}" bindtap="next">下一步：确认订单</button>
  </view>
</view>
