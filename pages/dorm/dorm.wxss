.flow-page {
  min-height: 100vh;
  padding-bottom: 158rpx;
  background: #f4f4f2;
  box-sizing: border-box;
}

.step-line {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-bottom: 34rpx;
}

.step {
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #9a9a9a;
  text-align: center;
  font-size: 22rpx;
  border: 1rpx solid #e8e8e3;
}

.step.active,
.step.done {
  background: #111111;
  color: #ffffff;
}

.step.locked {
  opacity: 0.48;
}

.step.clickable {
  transform: translateZ(0);
}

.title-block {
  margin-bottom: 24rpx;
}

.map-card,
.form-card,
.delivery-card {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.map-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.block-title {
  font-size: 30rpx;
  font-weight: 900;
}

.map-current {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #111111;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 900;
}

.dorm-map {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx 12rpx;
  height: auto;
  min-height: 574rpx;
  border-radius: 30rpx;
  overflow: hidden;
  padding: 18rpx 16rpx;
  background: radial-gradient(circle at 50% 45%, rgba(255, 255, 255, 0.78) 0%, rgba(242, 241, 237, 0.92) 42%, #eeede8 100%);
  box-shadow: inset 0 0 0 2rpx rgba(205, 205, 198, 0.8);
  box-sizing: border-box;
}

.dorm-building {
  position: relative;
  z-index: 3;
  width: 100%;
  height: 132rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.building-body {
  position: absolute;
  left: 8rpx;
  right: 8rpx;
  top: 8rpx;
  bottom: 8rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #f7f7f4 0%, #e5e5e0 100%);
  border: 1rpx solid rgba(190, 190, 184, 0.72);
  box-shadow: 0 7rpx 0 rgba(130, 130, 126, 0.14), 0 16rpx 26rpx rgba(20, 20, 20, 0.05);
}

.building-label {
  position: relative;
  z-index: 2;
  color: #777777;
  font-size: 27rpx;
  font-weight: 900;
  text-align: center;
  text-shadow: 0 3rpx 0 #ffffff, 0 0 12rpx rgba(255, 255, 255, 0.8);
  white-space: nowrap;
}

.dorm-building.selected .building-body {
  background: linear-gradient(180deg, #1c1c1c 0%, #53534f 100%);
  border-color: #111111;
  box-shadow: 0 10rpx 0 rgba(0, 0, 0, 0.28), 0 18rpx 34rpx rgba(0, 0, 0, 0.2);
}

.dorm-building.selected .building-label {
  color: #ffffff;
  text-shadow: 0 2rpx 0 rgba(0, 0, 0, 0.5);
}

.dorm-building.disabled {
  opacity: 0.32;
  pointer-events: none;
}

.text-input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: #f7f7f4;
  border: 1rpx solid #ededed;
  font-size: 25rpx;
}

.text-input {
  height: 88rpx;
  margin-top: 16rpx;
  padding: 0 22rpx;
}

.textarea {
  min-height: 150rpx;
  margin-top: 16rpx;
  padding: 22rpx;
}

.delivery-row {
  color: #666666;
  font-size: 24rpx;
  line-height: 1.75;
}

.bottom-action {
  width: 100%;
  box-sizing: border-box;
}

.fixed-action {
  position: fixed;
  z-index: 20;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(244, 244, 242, 0.96);
  box-shadow: 0 -12rpx 34rpx rgba(20, 20, 20, 0.08);
  box-sizing: border-box;
}
