.member-page {
  min-height: 100vh;
  padding: 32rpx 0 56rpx;
  background: linear-gradient(180deg, #2b2f45 0%, #f5f5f3 430rpx);
  box-sizing: border-box;
}

.page-title {
  color: #ffffff;
  text-align: center;
  font-size: 36rpx;
  font-weight: 900;
  margin: 18rpx 0 38rpx;
}

.level-swiper {
  height: 360rpx;
}

.member-card {
  position: relative;
  height: 310rpx;
  margin: 0 28rpx;
  padding: 42rpx 38rpx;
  border-radius: 30rpx;
  color: #ffffff;
  overflow: hidden;
  box-shadow: 0 22rpx 54rpx rgba(0,0,0,0.2);
  box-sizing: border-box;
}

.member-card::after {
  content: "";
  position: absolute;
  right: -40rpx;
  bottom: -80rpx;
  width: 320rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.12);
}

.level-basic {
  background: linear-gradient(135deg, #dfe3e5, #9ca3a8);
}

.level-mid {
  background: linear-gradient(135deg, #34373c, #111111);
}

.level-goal {
  background: linear-gradient(135deg, #111111 0%, #38404b 52%, #d9d3c4 100%);
}

.current-tag {
  position: absolute;
  right: 0;
  top: 0;
  padding: 12rpx 24rpx;
  border-radius: 0 0 0 24rpx;
  background: rgba(0,0,0,0.34);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
}

.card-name {
  font-size: 42rpx;
  font-weight: 950;
}

.card-life {
  margin-top: 10rpx;
  font-size: 24rpx;
  opacity: 0.72;
}

.card-points {
  margin-top: 70rpx;
  font-size: 50rpx;
  font-weight: 950;
}

.card-points text,
.card-rule {
  font-size: 24rpx;
  opacity: 0.78;
}

.benefit-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  margin: 28rpx;
}

.benefit-item {
  min-height: 150rpx;
  padding: 22rpx 10rpx;
  border-radius: 26rpx;
  background: #ffffff;
  text-align: center;
  box-shadow: 0 12rpx 28rpx rgba(20,20,20,0.05);
  box-sizing: border-box;
}

.benefit-icon {
  font-size: 34rpx;
  font-weight: 950;
}

.benefit-title {
  margin-top: 10rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.benefit-copy {
  margin-top: 6rpx;
  color: #888888;
  font-size: 20rpx;
}

.module-card {
  margin: 0 28rpx 24rpx;
  padding: 30rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 34rpx rgba(20,20,20,0.05);
}

.module-title {
  font-size: 32rpx;
  font-weight: 950;
  margin-bottom: 24rpx;
}

.task-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.task-mark {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: #111111;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 950;
}

.task-info {
  flex: 1;
}

.task-info view {
  font-size: 28rpx;
  font-weight: 900;
}

.task-info text,
.rule-row {
  color: #777777;
  font-size: 24rpx;
  line-height: 1.7;
}

.task-row button {
  width: 146rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  padding: 0;
  background: #111111;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
}
