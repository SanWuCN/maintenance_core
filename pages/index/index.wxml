<view class="home-wrap">
  <scroll-view class="home page-shell" scroll-y enhanced show-scrollbar="{{false}}">
    <swiper class="poster-swiper" circular indicator-dots autoplay interval="8000" duration="500">
      <swiper-item wx:for="{{posters}}" wx:key="*this">
        <view class="poster-card">
          <image class="poster-image" src="{{item}}" mode="aspectFill"></image>
        </view>
      </swiper-item>
    </swiper>

    <view class="business-grid">
      <view class="business-item" hover-class="business-item-pressed" hover-start-time="10" bindtap="goService">
        <view class="deco-top-line"></view>
        <view class="deco-top-block"></view>
        <view class="deco-right-lines"></view>
        <view class="deco-corner-bg"><view class="dot-matrix"></view></view>
        <view class="card-content">
          <view class="business-icon-wrap">
            <image class="business-icon business-icon-dark" src="{{businessIcons.clean}}" mode="aspectFit"></image>
            <image class="business-icon business-icon-light" src="{{businessIcons.cleanWhite}}" mode="aspectFit"></image>
          </view>
          <view class="business-title">清灰维护</view>
          <view class="bottom-area">
            <view class="icon-arrow">→</view>
            <view class="bottom-deco">
              <view class="line-bottom"></view>
              <view class="dots-bottom">
                <view class="dot"></view><view class="dot"></view><view class="dot"></view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="business-item" hover-class="business-item-pressed" bindtap="comingSoon">
        <view class="deco-top-line"></view>
        <view class="deco-top-block"></view>
        <view class="deco-right-lines"></view>
        <view class="deco-corner-bg"><view class="dot-matrix"></view></view>
        <view class="card-content">
          <view class="business-icon-wrap">
            <image class="business-icon business-icon-dark" src="{{businessIcons.upgrade}}" mode="aspectFit"></image>
            <image class="business-icon business-icon-light" src="{{businessIcons.upgradeWhite}}" mode="aspectFit"></image>
          </view>
          <view class="business-title">硬件升级</view>
          <view class="bottom-area">
            <view class="icon-arrow">→</view>
            <view class="bottom-deco">
              <view class="line-bottom"></view>
              <view class="dots-bottom">
                <view class="dot"></view><view class="dot"></view><view class="dot"></view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="business-item" hover-class="business-item-pressed" bindtap="comingSoon">
        <view class="deco-top-line"></view>
        <view class="deco-top-block"></view>
        <view class="deco-right-lines"></view>
        <view class="deco-corner-bg"><view class="dot-matrix"></view></view>
        <view class="card-content">
          <view class="business-icon-wrap">
            <image class="business-icon business-icon-dark" src="{{businessIcons.optimize}}" mode="aspectFit"></image>
            <image class="business-icon business-icon-light" src="{{businessIcons.optimizeWhite}}" mode="aspectFit"></image>
          </view>
          <view class="business-title">系统优化</view>
          <view class="bottom-area">
            <view class="icon-arrow">→</view>
            <view class="bottom-deco">
              <view class="line-bottom"></view>
              <view class="dots-bottom">
                <view class="dot"></view><view class="dot"></view><view class="dot"></view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <auth-modal visible="{{loginPanelVisible}}" bindclose="closeLoginPanel" bindsuccess="onLoginSuccess"></auth-modal>
</view>
