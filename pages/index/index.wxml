<view class="home-wrap">
  <scroll-view class="home page-shell" scroll-y enhanced show-scrollbar="{{false}}">
    <swiper class="poster-swiper" circular indicator-dots autoplay interval="8000" duration="500">
      <swiper-item wx:for="{{posters}}" wx:key="*this">
        <view class="poster-card">
          <image class="poster-image" src="{{item}}" mode="aspectFill"></image>
        </view>
      </swiper-item>
    </swiper>

    <view class="business-grid">
      <view class="business-item" hover-class="business-item-pressed" hover-start-time="10" bindtap="goService">
        <view class="deco-top-line"></view>
        <view class="deco-top-block"></view>
        <view class="deco-right-lines"></view>
        <view class="deco-corner-bg"><view class="dot-matrix"></view></view>
        <view class="card-content">
          <view class="business-icon-wrap">
            <image class="business-icon business-icon-dark" src="{{businessIcons.clean}}" mode="aspectFit"></image>
            <image class="business-icon business-icon-light" src="{{businessIcons.cleanWhite}}" mode="aspectFit"></image>
          </view>
          <view class="business-title">清灰维护</view>
          <view class="bottom-area">
            <view class="icon-arrow">→</view>
            <view class="bottom-deco">
              <view class="line-bottom"></view>
              <view class="dots-bottom">
                <view class="dot"></view><view class="dot"></view><view class="dot"></view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="business-item" hover-class="business-item-pressed" bindtap="comingSoon">
        <view class="deco-top-line"></view>
        <view class="deco-top-block"></view>
        <view class="deco-right-lines"></view>
        <view class="deco-corner-bg"><view class="dot-matrix"></view></view>
        <view class="card-content">
          <view class="business-icon-wrap">
            <image class="business-icon business-icon-dark" src="{{businessIcons.upgrade}}" mode="aspectFit"></image>
            <image class="business-icon business-icon-light" src="{{businessIcons.upgradeWhite}}" mode="aspectFit"></image>
          </view>
          <view class="business-title">硬件升级</view>
          <view class="bottom-area">
            <view class="icon-arrow">→</view>
            <view class="bottom-deco">
              <view class="line-bottom"></view>
              <view class="dots-bottom">
                <view class="dot"></view><view class="dot"></view><view class="dot"></view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="business-item" hover-class="business-item-pressed" bindtap="comingSoon">
        <view class="deco-top-line"></view>
        <view class="deco-top-block"></view>
        <view class="deco-right-lines"></view>
        <view class="deco-corner-bg"><view class="dot-matrix"></view></view>
        <view class="card-content">
          <view class="business-icon-wrap">
            <image class="business-icon business-icon-dark" src="{{businessIcons.optimize}}" mode="aspectFit"></image>
            <image class="business-icon business-icon-light" src="{{businessIcons.optimizeWhite}}" mode="aspectFit"></image>
          </view>
          <view class="business-title">系统优化</view>
          <view class="bottom-area">
            <view class="icon-arrow">→</view>
            <view class="bottom-deco">
              <view class="line-bottom"></view>
              <view class="dots-bottom">
                <view class="dot"></view><view class="dot"></view><view class="dot"></view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{loginPanelVisible}}" class="login-mask">
    <view class="login-card">
      <view class="login-circuit login-circuit-left"></view>
      <view class="login-circuit login-circuit-right"></view>
      <view class="login-dot-line login-dot-line-top">
        <view class="login-dot"></view>
        <view class="login-wire"></view>
        <view class="login-dot login-dot-dark"></view>
      </view>
      <view class="login-close" bindtap="closeLoginPanel">
        <view class="close-line close-line-a"></view>
        <view class="close-line close-line-b"></view>
      </view>

      <view class="login-title" wx:if="{{loginStep === 'phone'}}">登录三物IT小屋</view>
      <view class="login-title" wx:else>注册三物IT小屋</view>
      <view class="login-copy" wx:if="{{loginStep === 'phone'}}">授权手机号后，用于预约联系和订单查询</view>
      <view class="login-copy" wx:else>完善头像和昵称后，即可自动创建账号</view>

      <block wx:if="{{loginStep === 'phone'}}">
        <view class="phone-auth-card">
          <view class="phone-icon">
            <view class="phone-speaker"></view>
            <view class="phone-button"></view>
          </view>
          <view class="phone-auth-title">微信手机号授权</view>
          <view class="phone-auth-copy">保护你的预约记录和会员积分</view>
        </view>
        <button class="login-primary" open-type="getPhoneNumber" bindgetphonenumber="onPhoneLogin">
          <text>授权手机号</text>
          <view class="button-circuit"></view>
        </button>
      </block>

      <block wx:else>
        <button class="avatar-picker" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image wx:if="{{loginForm.avatarUrl}}" class="avatar-img" src="{{loginForm.avatarUrl}}" mode="aspectFill"></image>
          <block wx:else>
            <view class="avatar-placeholder">
              <view class="avatar-head"></view>
              <view class="avatar-body"></view>
            </view>
            <view class="camera-badge">
              <view class="camera-body"></view>
              <view class="camera-lens"></view>
            </view>
            <view class="avatar-label">上传头像</view>
          </block>
        </button>
        <view class="nick-field">
          <view class="nick-icon">
            <view class="nick-icon-head"></view>
            <view class="nick-icon-body"></view>
          </view>
          <input class="nick-input" type="nickname" placeholder="填写昵称" value="{{loginForm.nickName}}" bindinput="onNickInput" />
        </view>
        <button class="login-primary" bindtap="completeLogin">
          <text>完成注册</text>
          <view class="button-circuit"></view>
        </button>
      </block>

      <view class="login-bottom-deco">
        <view class="login-bottom-line"></view>
        <view class="login-bottom-dots">
          <view></view><view></view><view></view><view></view><view></view>
        </view>
        <view class="login-bottom-line"></view>
      </view>
    </view>
  </view>
</view>
