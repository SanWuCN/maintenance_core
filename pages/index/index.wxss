.home-wrap {
  min-height: 100vh;
  position: relative;
}

.boot-screen {
  position: fixed;
  z-index: 20;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: #f4f4f2;
  display: flex;
  align-items: center;
  justify-content: center;
}

.boot-stage {
  position: relative;
  width: 178rpx;
  height: 220rpx;
}

.boot-logo {
  position: absolute;
  left: 23rpx;
  top: 8rpx;
  width: 132rpx;
  height: 132rpx;
  transform-origin: 50% 82%;
  animation: boot-hop-roll 2150ms cubic-bezier(0.18, 0.88, 0.22, 1) infinite;
}

.boot-shadow {
  position: absolute;
  left: 45rpx;
  bottom: 38rpx;
  width: 88rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: radial-gradient(ellipse at center, rgba(12, 12, 12, 0.28) 0%, rgba(12, 12, 12, 0.16) 42%, rgba(12, 12, 12, 0) 76%);
  transform-origin: 50% 50%;
  animation: boot-shadow-pulse 2150ms cubic-bezier(0.18, 0.88, 0.22, 1) infinite;
}

@keyframes boot-hop-roll {
  0% {
    transform: translate3d(-8rpx, -132rpx, 0) rotate(-32deg) scale(1);
  }
  16% {
    transform: translate3d(0, 0, 0) rotate(0deg) scale(1.08, 0.92);
  }
  24% {
    transform: translate3d(0, -18rpx, 0) rotate(10deg) scale(0.96, 1.04);
  }
  42% {
    transform: translate3d(15rpx, -86rpx, 0) rotate(74deg) scale(1);
  }
  58% {
    transform: translate3d(24rpx, 0, 0) rotate(136deg) scale(1.05, 0.95);
  }
  70% {
    transform: translate3d(18rpx, -28rpx, 0) rotate(166deg) scale(0.98, 1.02);
  }
  84% {
    transform: translate3d(0, 0, 0) rotate(180deg) scale(1.03, 0.97);
  }
  100% {
    transform: translate3d(-8rpx, -132rpx, 0) rotate(328deg) scale(1);
  }
}

@keyframes boot-shadow-pulse {
  0% {
    opacity: 0.06;
    transform: scale(0.42, 0.7);
  }
  16% {
    opacity: 0.34;
    transform: scale(1.08, 1);
  }
  42% {
    opacity: 0.12;
    transform: translateX(14rpx) scale(0.58, 0.78);
  }
  58% {
    opacity: 0.3;
    transform: translateX(24rpx) scale(1, 0.92);
  }
  70% {
    opacity: 0.18;
    transform: translateX(18rpx) scale(0.74, 0.82);
  }
  84% {
    opacity: 0.3;
    transform: scale(0.94, 0.92);
  }
  100% {
    opacity: 0.06;
    transform: scale(0.42, 0.7);
  }
}

.home {
  padding: 18rpx 0 26rpx;
  opacity: 1;
  transition: opacity 180ms ease;
}

.home-hidden {
  opacity: 0;
}

.home-ready {
  opacity: 1;
}

.poster-swiper {
  height: 936rpx;
}

.poster-card {
  position: relative;
  height: 100%;
  margin: 0 24rpx;
  padding: 10rpx;
  border-radius: 38rpx;
  border: 1rpx solid rgba(20, 20, 20, 0.07);
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.98), rgba(238, 238, 235, 0.88));
  box-shadow: 0 20rpx 54rpx rgba(10, 10, 10, 0.16), 0 2rpx 0 rgba(255, 255, 255, 0.95) inset;
  box-sizing: border-box;
  overflow: hidden;
}

.poster-image {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 30rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
  overflow: hidden;
  background: #e8e8e4;
}

.business-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin: 26rpx 24rpx 26rpx;
}

.business-item {
  position: relative;
  height: 318rpx;
  padding: 28rpx 14rpx;
  border-radius: 26rpx;
  border: 1rpx solid rgba(18, 18, 18, 0.06);
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.98), rgba(248, 248, 246, 0.96));
  color: #111111;
  box-shadow: 0 18rpx 34rpx rgba(12, 12, 12, 0.08), 0 1rpx 0 rgba(255, 255, 255, 0.95) inset;
  box-sizing: border-box;
  overflow: hidden;
  transition: background-color 180ms ease, color 180ms ease, transform 180ms ease, box-shadow 180ms ease;
}

.business-item::before,
.business-item::after {
  content: "";
  position: absolute;
  pointer-events: none;
}

.business-item::before {
  display: none;
}

.business-item::after {
  right: -8rpx;
  top: 18rpx;
  width: 92rpx;
  height: 210rpx;
  border-top: 1rpx solid rgba(16, 20, 24, 0.12);
  border-right: 1rpx solid rgba(16, 20, 24, 0.12);
  transform: skewX(-20deg);
}

.business-item-pressed {
  background: #151515;
  color: #ffffff;
  transform: translateY(3rpx) scale(0.985);
  box-shadow: 0 8rpx 20rpx rgba(15, 15, 15, 0.2);
}

.business-item-pressed::after {
  border-color: rgba(255, 255, 255, 0.2);
}

.business-mark {
  position: absolute;
  top: 24rpx;
  left: 18rpx;
  width: 42rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: currentColor;
  transform: skewX(-28deg);
}

.business-mark::after {
  content: "";
  position: absolute;
  left: 52rpx;
  top: 2rpx;
  width: 118rpx;
  height: 1rpx;
  background: rgba(16, 20, 24, 0.14);
}

.business-item-pressed .business-mark::after {
  background: rgba(255, 255, 255, 0.18);
}

.business-ui {
  position: absolute;
  left: 50%;
  top: 70rpx;
  width: 78rpx;
  height: 78rpx;
  color: currentColor;
  opacity: 0.92;
  transform: translateX(-50%);
}

.fan-ui {
  border: 7rpx solid currentColor;
  border-radius: 50%;
  box-sizing: border-box;
}

.fan-blade {
  position: absolute;
  left: 29rpx;
  top: 8rpx;
  width: 20rpx;
  height: 29rpx;
  border-radius: 18rpx 18rpx 6rpx 6rpx;
  background: currentColor;
  transform-origin: 10rpx 31rpx;
}

.fan-blade-b {
  transform: rotate(90deg);
}

.fan-blade-c {
  transform: rotate(180deg);
}

.fan-blade-d {
  transform: rotate(270deg);
}

.fan-core {
  position: absolute;
  left: 24rpx;
  top: 24rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #f8f8f6;
  border: 5rpx solid currentColor;
}

.business-item-pressed .fan-core {
  background: #151515;
}

.chip-ui {
  width: 70rpx;
  height: 70rpx;
  border: 7rpx solid currentColor;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.chip-ui::before,
.chip-ui::after {
  content: "";
  position: absolute;
  background: currentColor;
}

.chip-ui::before {
  left: -18rpx;
  top: 10rpx;
  width: 12rpx;
  height: 7rpx;
  box-shadow: 0 17rpx 0 currentColor, 0 34rpx 0 currentColor, 64rpx 0 0 currentColor, 64rpx 17rpx 0 currentColor, 64rpx 34rpx 0 currentColor, 17rpx -28rpx 0 currentColor, 34rpx -28rpx 0 currentColor, 17rpx 62rpx 0 currentColor, 34rpx 62rpx 0 currentColor;
}

.chip-ui::after {
  left: 12rpx;
  top: 12rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
  box-shadow: 27rpx 27rpx 0 currentColor;
}

.chip-dot {
  display: none;
}

.gear-ui {
  background: currentColor;
  clip-path: polygon(43% 0, 57% 0, 62% 15%, 74% 20%, 88% 13%, 99% 25%, 92% 39%, 98% 51%, 100% 64%, 85% 69%, 80% 81%, 85% 95%, 71% 100%, 58% 91%, 43% 91%, 29% 100%, 15% 94%, 20% 80%, 15% 68%, 0 63%, 2% 48%, 8% 38%, 1% 24%, 14% 13%, 27% 20%, 38% 15%);
}

.gear-ui::after {
  content: "";
  position: absolute;
  left: 24rpx;
  top: 24rpx;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: #f8f8f6;
}

.business-item-pressed .gear-ui::after {
  background: #151515;
}

.business-title {
  position: absolute;
  left: 10rpx;
  right: 10rpx;
  top: 174rpx;
  font-size: 32rpx;
  line-height: 1.15;
  font-weight: 800;
  text-align: center;
}

.business-deco {
  position: absolute;
  left: 18rpx;
  right: 20rpx;
  bottom: 26rpx;
  width: auto;
  height: 8rpx;
  border-bottom: 2rpx solid rgba(20, 20, 20, 0.18);
}

.business-deco::before,
.business-deco::after {
  content: "";
  position: absolute;
  bottom: -2rpx;
  height: 2rpx;
  background: rgba(20, 20, 20, 0.28);
}

.business-deco::before {
  left: 0;
  width: 16rpx;
}

.business-deco::after {
  right: -42rpx;
  width: 6rpx;
  box-shadow: 18rpx 0 0 rgba(20, 20, 20, 0.2), 36rpx 0 0 rgba(20, 20, 20, 0.16);
}

.business-item-pressed .business-deco {
  border-color: rgba(255, 255, 255, 0.25);
}

.business-item-pressed .business-deco::before,
.business-item-pressed .business-deco::after {
  background: rgba(255, 255, 255, 0.42);
  box-shadow: 18rpx 0 0 rgba(255, 255, 255, 0.28), 36rpx 0 0 rgba(255, 255, 255, 0.18);
}
