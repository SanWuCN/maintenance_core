.home-wrap {
  min-height: 100vh;
  position: relative;
}

.boot-screen {
  position: fixed;
  z-index: 20;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: #f4f4f2;
  display: flex;
  align-items: center;
  justify-content: center;
}

.boot-stage {
  position: relative;
  width: 178rpx;
  height: 220rpx;
}

.boot-logo {
  position: absolute;
  left: 23rpx;
  top: 8rpx;
  width: 132rpx;
  height: 132rpx;
  transform-origin: 50% 82%;
  animation: boot-hop-roll 2150ms cubic-bezier(0.18, 0.88, 0.22, 1) infinite;
}

.boot-shadow {
  position: absolute;
  left: 45rpx;
  bottom: 38rpx;
  width: 88rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: radial-gradient(ellipse at center, rgba(12, 12, 12, 0.28) 0%, rgba(12, 12, 12, 0.16) 42%, rgba(12, 12, 12, 0) 76%);
  transform-origin: 50% 50%;
  animation: boot-shadow-pulse 2150ms cubic-bezier(0.18, 0.88, 0.22, 1) infinite;
}

@keyframes boot-hop-roll {
  0% {
    transform: translate3d(-8rpx, -132rpx, 0) rotate(-32deg) scale(1);
  }
  16% {
    transform: translate3d(0, 0, 0) rotate(0deg) scale(1.08, 0.92);
  }
  24% {
    transform: translate3d(0, -18rpx, 0) rotate(10deg) scale(0.96, 1.04);
  }
  42% {
    transform: translate3d(15rpx, -86rpx, 0) rotate(74deg) scale(1);
  }
  58% {
    transform: translate3d(24rpx, 0, 0) rotate(136deg) scale(1.05, 0.95);
  }
  70% {
    transform: translate3d(18rpx, -28rpx, 0) rotate(166deg) scale(0.98, 1.02);
  }
  84% {
    transform: translate3d(0, 0, 0) rotate(180deg) scale(1.03, 0.97);
  }
  100% {
    transform: translate3d(-8rpx, -132rpx, 0) rotate(328deg) scale(1);
  }
}

@keyframes boot-shadow-pulse {
  0% {
    opacity: 0.06;
    transform: scale(0.42, 0.7);
  }
  16% {
    opacity: 0.34;
    transform: scale(1.08, 1);
  }
  42% {
    opacity: 0.12;
    transform: translateX(14rpx) scale(0.58, 0.78);
  }
  58% {
    opacity: 0.3;
    transform: translateX(24rpx) scale(1, 0.92);
  }
  70% {
    opacity: 0.18;
    transform: translateX(18rpx) scale(0.74, 0.82);
  }
  84% {
    opacity: 0.3;
    transform: scale(0.94, 0.92);
  }
  100% {
    opacity: 0.06;
    transform: scale(0.42, 0.7);
  }
}

.home {
  padding: 18rpx 0 26rpx;
  opacity: 1;
  transition: opacity 180ms ease;
}

.home-hidden {
  opacity: 0;
}

.home-ready {
  opacity: 1;
}

.poster-swiper {
  height: 936rpx;
}

.poster-card {
  position: relative;
  height: 100%;
  margin: 0 24rpx;
  padding: 10rpx;
  border-radius: 38rpx;
  border: 1rpx solid rgba(20, 20, 20, 0.07);
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.98), rgba(238, 238, 235, 0.88));
  box-shadow: 0 20rpx 54rpx rgba(10, 10, 10, 0.16), 0 2rpx 0 rgba(255, 255, 255, 0.95) inset;
  box-sizing: border-box;
  overflow: hidden;
}

.poster-image {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 30rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
  overflow: hidden;
  background: #e8e8e4;
}

.business-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin: 26rpx 24rpx 26rpx;
}

.business-item {
  position: relative;
  height: 272rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(20, 20, 20, 0.06);
  background: #ffffff;
  color: #111111;
  box-shadow: 0 18rpx 36rpx rgba(12, 12, 12, 0.08);
  box-sizing: border-box;
  overflow: hidden;
  transition: background-color 180ms ease, color 180ms ease, transform 180ms ease, box-shadow 180ms ease;
}

.business-item-pressed {
  background: #151515;
  color: #ffffff;
  transform: translateY(3rpx) scale(0.985);
  box-shadow: 0 8rpx 20rpx rgba(15, 15, 15, 0.2);
}

.deco-top-line {
  position: absolute;
  top: 24rpx;
  left: 12rpx;
  right: 12rpx;
  height: 44rpx;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='220' height='44' viewBox='0 0 220 44'><path d='M0 26 L18 26 M78 26 L128 26 L148 6 L220 6' stroke='%23bcc0c4' stroke-width='1.4' fill='none'/></svg>");
  background-repeat: no-repeat;
  background-size: 100% 100%;
  opacity: 0.82;
  pointer-events: none;
}

.deco-top-block {
  position: absolute;
  top: 42rpx;
  left: 26rpx;
  width: 48rpx;
  height: 8rpx;
  background: currentColor;
  transform: skewX(-42deg);
  pointer-events: none;
}

.deco-right-lines {
  position: absolute;
  right: 0;
  top: 54rpx;
  width: 74rpx;
  height: 170rpx;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 86 208'><path d='M76 0 V42 L48 72 V118 L2 180' stroke='%23c0c4c8' stroke-width='1.5' fill='none'/><path d='M84 44 V74 L58 104' stroke='%23e1e3e5' stroke-width='1.5' fill='none'/></svg>");
  background-repeat: no-repeat;
  background-size: 100% 100%;
  opacity: 0.85;
  pointer-events: none;
  z-index: 2;
}

.deco-corner-bg {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 108rpx;
  height: 108rpx;
  background: linear-gradient(135deg, rgba(246, 247, 248, 0), rgba(238, 239, 241, 0.95));
  clip-path: polygon(100% 0, 100% 100%, 0 100%, 18% 84%, 36% 84%, 68% 52%, 68% 30%);
  z-index: 1;
  pointer-events: none;
}

.dot-matrix {
  position: absolute;
  right: 14rpx;
  bottom: 14rpx;
  width: 44rpx;
  height: 36rpx;
  background-image: radial-gradient(rgba(176, 180, 184, 0.95) 2.6rpx, transparent 2.6rpx);
  background-size: 14rpx 14rpx;
}

.card-content {
  position: relative;
  z-index: 3;
  width: 100%;
  height: 100%;
  padding: 62rpx 18rpx 18rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.business-icon-wrap {
  position: relative;
  width: 72rpx;
  height: 72rpx;
}

.business-icon {
  position: absolute;
  left: 0;
  top: 0;
  width: 72rpx;
  height: 72rpx;
  transition: opacity 160ms ease;
}

.business-icon-light {
  opacity: 0;
}

.business-item-pressed .business-icon-dark {
  opacity: 0;
}

.business-item-pressed .business-icon-light {
  opacity: 1;
}

.business-title {
  margin-top: 18rpx;
  font-size: 30rpx;
  line-height: 1.15;
  font-weight: 800;
  text-align: center;
  white-space: nowrap;
}

.bottom-area {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  bottom: 16rpx;
  display: flex;
  align-items: center;
}

.icon-arrow {
  width: 38rpx;
  height: 38rpx;
  border: 2rpx solid rgba(120, 124, 128, 0.72);
  border-radius: 50%;
  line-height: 33rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 300;
  box-sizing: border-box;
}

.bottom-deco {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  margin-left: 12rpx;
}

.line-bottom {
  flex: 1;
  height: 2rpx;
  background: rgba(188, 192, 196, 0.72);
}

.dots-bottom {
  display: flex;
  gap: 8rpx;
  margin-left: 10rpx;
}

.dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(176, 180, 184, 0.92);
}

.business-item-pressed .deco-top-line,
.business-item-pressed .deco-right-lines {
  opacity: 0.34;
  filter: invert(1);
}

.business-item-pressed .deco-corner-bg {
  background: rgba(255, 255, 255, 0.08);
}

.business-item-pressed .line-bottom,
.business-item-pressed .dot,
.business-item-pressed .dot-matrix {
  opacity: 0.7;
  filter: invert(1);
}

.business-item-pressed .icon-arrow {
  border-color: rgba(255, 255, 255, 0.45);
}
