.home {
  padding: 18rpx 24rpx 42rpx;
}

.poster-swiper {
  height: 936rpx;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 18rpx 46rpx rgba(10, 10, 10, 0.09);
}

.poster-card {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  border-radius: 28rpx;
  background: #e8e8e4;
}

.poster-image {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
}

.business-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
  margin-top: 22rpx;
}

.business-item {
  position: relative;
  height: 172rpx;
  padding: 28rpx 18rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(20, 20, 20, 0.07);
  background: rgba(255, 255, 255, 0.92);
  color: #111111;
  box-shadow: 0 12rpx 30rpx rgba(15, 15, 15, 0.06);
  box-sizing: border-box;
  overflow: hidden;
  transition: background-color 180ms ease, color 180ms ease, transform 180ms ease, box-shadow 180ms ease;
}

.business-item::before,
.business-item::after {
  content: "";
  position: absolute;
  pointer-events: none;
}

.business-item::before {
  top: 12rpx;
  left: 18rpx;
  width: 42rpx;
  height: 6rpx;
  background: currentColor;
  transform: skewX(-28deg);
}

.business-item::after {
  right: 12rpx;
  top: 14rpx;
  width: 82rpx;
  height: 56rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.12);
  border-right: 1rpx solid rgba(0, 0, 0, 0.12);
  transform: skewX(-18deg);
}

.business-item-pressed {
  background: #151515;
  color: #ffffff;
  transform: translateY(3rpx) scale(0.985);
  box-shadow: 0 8rpx 20rpx rgba(15, 15, 15, 0.18);
}

.business-item-pressed::after {
  border-color: rgba(255, 255, 255, 0.18);
}

.business-mark {
  width: 26rpx;
  height: 5rpx;
  margin-bottom: 22rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.business-title {
  font-size: 28rpx;
  line-height: 1.15;
  font-weight: 800;
}

.business-desc {
  margin-top: 10rpx;
  color: #777777;
  font-size: 19rpx;
  line-height: 1.25;
  white-space: nowrap;
}

.business-item-pressed .business-desc {
  color: #cfcfcf;
}

.business-deco {
  position: absolute;
  left: 18rpx;
  bottom: 18rpx;
  width: 86rpx;
  height: 8rpx;
  border-bottom: 2rpx solid rgba(20, 20, 20, 0.18);
}

.business-deco::before,
.business-deco::after {
  content: "";
  position: absolute;
  bottom: -2rpx;
  height: 2rpx;
  background: rgba(20, 20, 20, 0.28);
}

.business-deco::before {
  left: 0;
  width: 16rpx;
}

.business-deco::after {
  right: -42rpx;
  width: 6rpx;
  box-shadow: 18rpx 0 0 rgba(20, 20, 20, 0.2), 36rpx 0 0 rgba(20, 20, 20, 0.16);
}

.business-item-pressed .business-deco {
  border-color: rgba(255, 255, 255, 0.25);
}

.business-item-pressed .business-deco::before,
.business-item-pressed .business-deco::after {
  background: rgba(255, 255, 255, 0.42);
  box-shadow: 18rpx 0 0 rgba(255, 255, 255, 0.28), 36rpx 0 0 rgba(255, 255, 255, 0.18);
}

.assurance {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.assurance-item {
  padding: 18rpx 10rpx;
  border: 1rpx solid rgba(20, 20, 20, 0.07);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.72);
  text-align: center;
}

.assurance-k {
  font-size: 24rpx;
  font-weight: 700;
}

.assurance-v {
  margin-top: 3rpx;
  color: #777777;
  font-size: 20rpx;
}
