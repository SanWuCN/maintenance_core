/* 全局半透明磨砂遮罩 */
.reg-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 100;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(5px);
  -webkit-backdrop-filter: blur(5px);
}

/* 弹窗核心视窗 */
.reg-modal {
  position: relative;
  width: 620rpx;
  padding: 60rpx 40rpx;
  border-radius: 40rpx;
  background: #ffffff;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 30rpx 80rpx rgba(0, 0, 0, 0.2);
  box-sizing: border-box;
  overflow: hidden;
}

/* 装饰几何线条 */
.reg-modal::before,
.reg-modal::after {
  content: '';
  position: absolute;
  pointer-events: none;
  opacity: 0.3;
  z-index: 0;
}

.reg-modal::before {
  left: -18rpx; top: 20rpx;
  width: 190rpx; height: 130rpx;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 190 130'><path d='M4 72 L52 72 L86 32 M16 116 L48 116 L66 92 L122 92' stroke='%23dddddd' stroke-width='2' fill='none'/><circle cx='52' cy='72' r='5' fill='%23d5d5d5'/><circle cx='122' cy='92' r='5' fill='%23222222'/></svg>");
  background-size: 100% 100%;
}

.reg-modal::after {
  right: -22rpx; bottom: 58rpx;
  width: 150rpx; height: 220rpx;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 150 220'><path d='M130 0 V48 L98 80 V122 L62 158 V214' stroke='%23dddddd' stroke-width='2' fill='none'/><path d='M148 66 V132 L118 160' stroke='%23eeeeee' stroke-width='2' fill='none'/></svg>");
  background-size: 100% 100%;
}

/* 优化点击区域的关闭按钮 */
.close-icon {
  position: absolute;
  right: 24rpx; top: 24rpx;
  width: 60rpx; height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  color: #999999;
  font-size: 48rpx;
  font-weight: 300;
}

/* 头部排版 */
.header-section {
  position: relative;
  z-index: 2;
  margin-bottom: 50rpx;
  text-align: center;
}

.main-title {
  color: #1a1a1a;
  font-size: 42rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.highlight {
  color: #111;
  font-weight: 900;
}

.sub-title {
  margin-top: 14rpx;
  color: #888888;
  font-size: 24rpx;
}

/* 中间图形包裹容器 */
.avatar-section,
.phone-section {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 50rpx;
}

.tech-frame {
  position: relative;
  width: 200rpx; height: 200rpx;
  padding: 10rpx;
  border: 2rpx dashed #dddddd;
  border-radius: 40rpx;
  box-sizing: border-box;
}

.phone-frame {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8f8f8;
}

/* 彻底重设微信 Button 默认宽高与内外边距属性 */
.avatar-wrapper {
  margin: 0 !important;
  padding: 0 !important;
  width: 100% !important; height: 100% !important;
  background: #f4f5f7;
  border-radius: 30rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none !important;
  outline: none;
}
.avatar-wrapper::after { border: none !important; display: none; }

.avatar-img {
  width: 100%; height: 100%;
  display: block;
}

/* 安全加载：默认空白时展示的极客人像背景占位图 */
.avatar-placeholder {
  width: 100%; height: 100%;
  background: #f4f5f7 url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%23dddddd'><path d='M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z'/></svg>") center center / 50% 50% no-repeat;
}

/* 按钮点击遮罩 */
.avatar-mask {
  position: absolute;
  left: 10rpx; right: 10rpx; top: 10rpx; bottom: 10rpx;
  border-radius: 30rpx;
  background: rgba(0, 0, 0, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.2s ease;
}
.avatar-wrapper:active .avatar-mask { opacity: 1; }

.upload-icon {
  width: 42rpx; height: 34rpx;
  border-radius: 7rpx;
  background: rgba(255, 255, 255, 0.9);
  position: relative;
}
.upload-icon::before {
  content: '';
  position: absolute;
  left: 13rpx; top: 9rpx;
  width: 16rpx; height: 16rpx;
  border: 4rpx solid #666;
  border-radius: 50%;
  box-sizing: border-box;
}

/* 绑定手机时的手机矢量骨架 */
.phone-mark {
  position: relative;
  width: 90rpx; height: 128rpx;
  border: 6rpx solid #1a1a1a;
  border-radius: 26rpx;
  box-sizing: border-box;
}
.phone-speaker {
  position: absolute;
  left: 28rpx; top: 14rpx;
  width: 24rpx; height: 5rpx;
  border-radius: 5rpx;
  background: #1a1a1a;
}
.phone-dot {
  position: absolute;
  left: 34rpx; bottom: 12rpx;
  width: 12rpx; height: 12rpx;
  border-radius: 50%;
  background: #1a1a1a;
}

/* 定位直角科技描边 */
.corner-tl, .corner-br {
  position: absolute;
  width: 30rpx; height: 30rpx;
  border-color: #111;
  border-style: solid;
  pointer-events: none;
  z-index: 5;
}
.corner-tl { top: -4rpx; left: -4rpx; border-width: 4rpx 0 0 4rpx; border-radius: 12rpx 0 0 0; }
.corner-br { right: -4rpx; bottom: -4rpx; border-width: 0 4rpx 4rpx 0; border-radius: 0 0 12rpx 0; }

.upload-hint {
  margin-top: 24rpx;
  color: #999;
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

/* 填写昵称框 */
.input-section {
  position: relative;
  z-index: 2;
  margin-bottom: 50rpx;
}

.input-item {
  height: 100rpx;
  padding: 0 30rpx;
  border-radius: 20rpx;
  background: #f6f7f9;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.icon-user {
  width: 36rpx; height: 36rpx;
  margin-right: 20rpx;
  background: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' fill='none' stroke='%23999' stroke-width='2' viewBox='0 0 24 24'><path d='M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2'/><circle cx='12' cy='7' r='4'/></svg>") center/contain no-repeat;
}

.nickname-input {
  flex: 1;
  color: #333;
  font-size: 30rpx;
  height: 100%;
}
.ph-style { color: #ccc; }

/* 底部操作大按钮重置 */
.submit-btn {
  position: relative;
  z-index: 2;
  width: 100% !important;
  height: 100rpx;
  margin: 0 !important;
  padding: 0 !important;
  border-radius: 50rpx;
  background: #111;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 32rpx rgba(0, 0, 0, 0.15);
}
.submit-btn::after { border: none !important; }

.btn-inner {
  position: relative;
  display: flex;
  align-items: center;
}

.btn-deco {
  position: absolute;
  bottom: -12rpx; left: 50%;
  width: 40rpx; height: 4rpx;
  border-radius: 2rpx;
  background: rgba(255, 255, 255, 0.4);
  transform: translateX(-50%);
}

/* 底部流水号装饰 */
.bottom-serial {
  position: relative;
  z-index: 2;
  margin-top: 34rpx;
  color: #d0d0d0;
  font-family: monospace;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  text-align: center;
}